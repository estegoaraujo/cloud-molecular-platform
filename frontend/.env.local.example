# ─── Supabase ────────────────────────────────────────────────────────────────
# Public project URL and anon key. These are SAFE to expose to the browser
# (the anon key only grants access permitted by Row Level Security policies).
# Find them in: Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ─── Backend (FastAPI physics API) ───────────────────────────────────────────
# Base URL of the FastAPI service. Used by the dashboard to POST simulations.
# Local dev default matches backend/README.md.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# NOTE: Never put the Supabase service_role key in a NEXT_PUBLIC_* variable.
# That key bypasses RLS and must live only on the backend (see backend/.env).
